{
  "name": "@forinda/kickjs-devtools-kit",
  "version": "6.0.0-alpha.0",
  "description": "Types, RPC envelopes, runtime sampler, and memory analyzer used by KickJS DevTools and any plugin that integrates with it",
  "keywords": [
    "kickjs",
    "nodejs",
    "typescript",
    "devtools-types",
    "rpc-envelopes",
    "runtime-sampler",
    "memory-analyzer",
    "leak-detection",
    "introspection",
    "monitoring"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./runtime": {
      "import": "./dist/runtime.mjs",
      "types": "./dist/runtime.d.mts"
    },
    "./types": {
      "import": "./dist/types.mjs",
      "types": "./dist/types.d.mts"
    },
    "./bus": {
      "import": "./dist/bus.mjs",
      "types": "./dist/bus.d.mts"
    },
    "./bus/token": {
      "import": "./dist/bus/token.mjs",
      "types": "./dist/bus/token.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "wireit",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "typecheck": "tsgo --noEmit",
    "clean": "rm -rf dist .wireit"
  },
  "wireit": {
    "build": {
      "command": "tsdown",
      "files": [
        "src/**/*.ts",
        "tsdown.config.ts",
        "tsconfig.json",
        "package.json"
      ],
      "output": [
        "dist/**"
      ]
    }
  },
  "dependencies": {},
  "peerDependencies": {
    "@forinda/kickjs": ">=5.14.0-alpha.0"
  },
  "peerDependenciesMeta": {
    "@forinda/kickjs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@forinda/kickjs": "workspace:*",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://forinda.github.io/kick-js/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/devtools-kit"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  }
}
