{
  "name": "@forinda/kickjs-inertia",
  "version": "3.0.5",
  "description": "Inertia protocol adapter for KickJS — serve SPA pages from controllers",
  "keywords": [
    "kickjs",
    "inertia",
    "spa",
    "ssr",
    "nodejs",
    "typescript",
    "express",
    "decorators",
    "dependency-injection",
    "backend",
    "api",
    "framework",
    "@forinda/kickjs"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "wireit",
    "dev": "tsdown --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .wireit",
    "lint": "tsc --noEmit"
  },
  "wireit": {
    "build": {
      "command": "tsdown",
      "files": [
        "src/**/*.ts",
        "tsdown.config.ts",
        "tsconfig.json",
        "package.json"
      ],
      "output": [
        "dist/**"
      ],
      "dependencies": [
        "../kickjs:build"
      ]
    }
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "@forinda/kickjs": ">=2.3.0"
  },
  "peerDependenciesMeta": {},
  "devDependencies": {
    "@forinda/kickjs": "workspace:*",
    "@swc/core": "^1.15.21",
    "@types/node": "^25.0.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://forinda.github.io/kick-js/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/inertia"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  }
}
