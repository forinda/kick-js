{
  "name": "@forinda/kickjs-vite",
  "version": "2.0.1",
  "description": "Vite plugin for KickJS — dev server integration, HMR, virtual modules, httpServer piping",
  "keywords": [
    "kickjs",
    "vite",
    "vite-plugin",
    "hmr",
    "hot-module-replacement",
    "dev-server",
    "nodejs",
    "typescript",
    "express",
    "backend",
    "framework"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "wireit",
    "dev": "tsdown --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .wireit"
  },
  "wireit": {
    "build": {
      "command": "tsdown",
      "files": ["src/**/*.ts", "tsdown.config.ts", "tsconfig.json", "package.json"],
      "output": ["dist/**"],
      "dependencies": ["../kickjs:build"]
    }
  },
  "dependencies": {
    "@forinda/kickjs": "workspace:*"
  },
  "peerDependencies": {
    "vite": ">=6.0.0",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "express": "^5.1.0",
    "typescript": "^5.9.2",
    "vite": "^8.0.7",
    "vitest": "^4.1.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://forinda.github.io/kick-js/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/vite"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  }
}
