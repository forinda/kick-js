{
  "name": "@forinda/kickjs-vite",
  "version": "6.1.0",
  "description": "Vite plugin for KickJS — dev server integration, HMR, virtual modules, httpServer piping",
  "keywords": [
    "kickjs",
    "nodejs",
    "typescript",
    "decorator-driven",
    "vite",
    "vite-plugin",
    "hmr",
    "hot-module-replacement",
    "dev-server",
    "ssr",
    "virtual-modules"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./globals": {
      "types": "./globals.d.ts"
    }
  },
  "files": [
    "dist",
    "globals.d.ts"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsgo --noEmit",
    "clean": "rm -rf dist .wireit"
  },
  "dependencies": {
    "@babel/core": "^7.29.7"
  },
  "peerDependencies": {
    "vite": ">=6.0.0",
    "express": "^5.1.0",
    "@forinda/kickjs": ">=5.14.0-alpha.0",
    "@forinda/kickjs-cli": ">=6.0.0"
  },
  "devDependencies": {
    "@forinda/kickjs": "workspace:*",
    "@types/babel__core": "^7.20.5",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.2",
    "express": "^5.1.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://forinda.github.io/kick-js/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/vite"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  },
  "peerDependenciesMeta": {
    "@forinda/kickjs-cli": {
      "optional": true
    }
  }
}
