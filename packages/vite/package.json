{
  "name": "@forinda/kickjs-vite",
  "version": "2.0.1",
  "description": "Vite plugin for KickJS — virtual modules, module discovery, selective HMR, dev server integration",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "scripts": {
    "build": "wireit",
    "dev": "tsdown --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .wireit"
  },
  "wireit": {
    "build": {
      "command": "tsdown",
      "files": ["src/**/*.ts", "tsdown.config.ts", "tsconfig.json", "package.json"],
      "output": ["dist/**"]
    }
  },
  "dependencies": {
    "@forinda/kickjs-core": "workspace:*"
  },
  "peerDependencies": {
    "vite": "^6.0.0 || ^7.0.0 || ^8.0.0"
  },
  "keywords": ["kickjs", "vite", "plugin", "hmr", "virtual-modules"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forinda/kick-js.git",
    "directory": "packages/vite"
  }
}
