{
  "name": "@forinda/kickjs-core",
  "version": "0.4.0",
  "description": "Core DI container, decorators, module system, and logger for KickJS",
  "keywords": [
    "kickjs",
    "nodejs",
    "typescript",
    "express",
    "decorators",
    "dependency-injection",
    "backend",
    "api",
    "framework",
    "di",
    "ioc",
    "container",
    "service",
    "controller",
    "module",
    "reactivity",
    "ref",
    "computed",
    "watch"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./container": {
      "import": "./dist/container.js",
      "types": "./dist/container.d.ts"
    },
    "./decorators": {
      "import": "./dist/decorators.js",
      "types": "./dist/decorators.d.ts"
    },
    "./module": {
      "import": "./dist/app-module.js",
      "types": "./dist/app-module.d.ts"
    },
    "./adapter": {
      "import": "./dist/adapter.js",
      "types": "./dist/adapter.d.ts"
    },
    "./logger": {
      "import": "./dist/logger.js",
      "types": "./dist/logger.d.ts"
    },
    "./errors": {
      "import": "./dist/errors.js",
      "types": "./dist/errors.d.ts"
    },
    "./types": {
      "import": "./dist/interfaces.js",
      "types": "./dist/interfaces.d.ts"
    },
    "./reactivity": {
      "import": "./dist/reactivity.js",
      "types": "./dist/reactivity.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@swc/core": "^1.7.28",
    "@types/node": "^24.5.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://forinda.github.io/kick-js/"
}
