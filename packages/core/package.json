{
  "name": "@forinda/kickjs-core",
  "version": "2.2.3",
  "description": "Core DI container, decorators, module system, and logger for KickJS",
  "keywords": [
    "kickjs",
    "nodejs",
    "typescript",
    "express",
    "decorators",
    "dependency-injection",
    "backend",
    "api",
    "framework",
    "di",
    "ioc",
    "container",
    "service",
    "controller",
    "module",
    "reactivity",
    "ref",
    "computed",
    "watch",
    "pino",
    "logger",
    "vite",
    "@forinda/kickjs",
    "@forinda/kickjs-auth",
    "@forinda/kickjs-cli",
    "@forinda/kickjs-config",
    "@forinda/kickjs-core",
    "@forinda/kickjs-cron",
    "@forinda/kickjs-devtools",
    "@forinda/kickjs-drizzle",
    "@forinda/kickjs-graphql",
    "@forinda/kickjs-http",
    "@forinda/kickjs-mailer",
    "@forinda/kickjs-multi-tenant",
    "@forinda/kickjs-notifications",
    "@forinda/kickjs-otel",
    "@forinda/kickjs-prisma",
    "@forinda/kickjs-queue",
    "@forinda/kickjs-swagger",
    "@forinda/kickjs-testing",
    "@forinda/kickjs-vite",
    "@forinda/kickjs-ws"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./container": {
      "import": "./dist/container.mjs",
      "types": "./dist/container.d.mts"
    },
    "./decorators": {
      "import": "./dist/decorators.mjs",
      "types": "./dist/decorators.d.mts"
    },
    "./module": {
      "import": "./dist/app-module.mjs",
      "types": "./dist/app-module.d.mts"
    },
    "./adapter": {
      "import": "./dist/adapter.mjs",
      "types": "./dist/adapter.d.mts"
    },
    "./logger": {
      "import": "./dist/logger.mjs",
      "types": "./dist/logger.d.mts"
    },
    "./errors": {
      "import": "./dist/errors.mjs",
      "types": "./dist/errors.d.mts"
    },
    "./types": {
      "import": "./dist/interfaces.mjs",
      "types": "./dist/interfaces.d.mts"
    },
    "./reactivity": {
      "import": "./dist/reactivity.mjs",
      "types": "./dist/reactivity.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "wireit",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .wireit",
    "lint": "tsc --noEmit"
  },
  "wireit": {
    "build": {
      "command": "tsdown",
      "files": [
        "src/**/*.ts",
        "tsdown.config.ts",
        "tsconfig.json",
        "package.json"
      ],
      "output": [
        "dist/**"
      ]
    }
  },
  "dependencies": {
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@swc/core": "^1.15.21",
    "@types/node": "^25.0.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://forinda.github.io/kick-js/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  }
}
