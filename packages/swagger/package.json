{
  "name": "@forinda/kickjs-swagger",
  "version": "2.0.1",
  "description": "OpenAPI spec generation from decorators, Swagger UI and ReDoc serving for KickJS",
  "keywords": [
    "kickjs",
    "nodejs",
    "typescript",
    "express",
    "decorators",
    "dependency-injection",
    "backend",
    "api",
    "framework",
    "openapi",
    "api-documentation",
    "redoc",
    "swagger-ui",
    "rest-api",
    "zod",
    "@forinda/kickjs-core",
    "@forinda/kickjs-http",
    "@forinda/kickjs-config",
    "@forinda/kickjs-cli",
    "@forinda/kickjs-testing",
    "@forinda/kickjs-prisma",
    "@forinda/kickjs-ws",
    "@forinda/kickjs-drizzle",
    "@forinda/kickjs-otel",
    "@forinda/kickjs-graphql",
    "@forinda/kickjs-auth",
    "@forinda/kickjs-cron",
    "@forinda/kickjs-mailer",
    "@forinda/kickjs-queue",
    "@forinda/kickjs-multi-tenant",
    "@forinda/kickjs-devtools",
    "@forinda/kickjs-notifications",
    "vite"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "wireit",
    "dev": "tsdown --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .wireit",
    "lint": "tsc --noEmit"
  },
  "wireit": {
    "build": {
      "command": "tsdown",
      "files": [
        "src/**/*.ts",
        "tsdown.config.ts",
        "tsconfig.json",
        "package.json"
      ],
      "output": [
        "dist/**"
      ],
      "dependencies": [
        "../core:build",
        "../http:build"
      ]
    }
  },
  "dependencies": {
    "@forinda/kickjs": "workspace:*",
    "reflect-metadata": "^0.2.2",
    "swagger-ui-dist": "^5.32.1"
  },
  "peerDependencies": {
    "express": "^5.1.0",
    "zod": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@swc/core": "^1.15.21",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.0",
    "express": "^5.1.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.2",
    "zod": "^4.3.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://forinda.github.io/kick-js/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/swagger"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  }
}
