{
  "name": "@forinda/kickjs-swagger",
  "version": "7.1.0",
  "description": "OpenAPI spec generation from decorators, Swagger UI and ReDoc serving for KickJS",
  "keywords": [
    "kickjs",
    "nodejs",
    "typescript",
    "decorator-driven",
    "openapi",
    "openapi-3",
    "swagger-ui",
    "redoc",
    "api-documentation",
    "zod-openapi",
    "rest-api",
    "schema-generation"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsgo --noEmit",
    "clean": "rm -rf dist .wireit"
  },
  "dependencies": {
    "@forinda/kickjs-schema": "workspace:*",
    "reflect-metadata": "^0.2.2",
    "swagger-ui-dist": "^5.32.9"
  },
  "peerDependencies": {
    "express": "^5.1.0",
    "zod": "^4.0.0",
    "@forinda/kickjs": ">=5.18.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@forinda/kickjs": "workspace:*",
    "@swc/core": "^1.15.43",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "express": "^5.1.0",
    "typescript": "^6.0.3",
    "valibot": "^1.4.2",
    "vitest": "^4.1.9",
    "yup": "^1.7.1",
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://kickjs.app/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/swagger"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  }
}
