{
  "name": "kickjs-devtools",
  "displayName": "KickJS DevTools",
  "description": "VS Code extension for inspecting KickJS applications — routes, DI container, metrics, and health",
  "version": "5.2.1",
  "publisher": "forinda",
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "resources/icon.png",
  "categories": [
    "Other",
    "Debuggers"
  ],
  "keywords": [
    "kickjs",
    "devtools",
    "nodejs",
    "express",
    "typescript",
    "decorator"
  ],
  "activationEvents": [
    "workspaceContains:**/kick.config.ts",
    "workspaceContains:**/kick.config.js",
    "workspaceContains:**/kick.config.json",
    "workspaceContains:**/node_modules/@forinda/kickjs/package.json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "kickjs.connect",
        "title": "KickJS: Connect to App…",
        "icon": "$(plug)"
      },
      {
        "command": "kickjs.inspect",
        "title": "KickJS: Inspect Running App"
      },
      {
        "command": "kickjs.showRoutes",
        "title": "KickJS: Show Routes"
      },
      {
        "command": "kickjs.showContainer",
        "title": "KickJS: Show DI Container"
      },
      {
        "command": "kickjs.showMetrics",
        "title": "KickJS: Show Metrics"
      },
      {
        "command": "kickjs.refreshAll",
        "title": "KickJS: Refresh All",
        "icon": "$(refresh)"
      },
      {
        "command": "kickjs.setToken",
        "title": "KickJS: Set DevTools Token…",
        "icon": "$(key)"
      },
      {
        "command": "kickjs.clearToken",
        "title": "KickJS: Clear DevTools Token"
      },
      {
        "command": "kickjs.dev",
        "title": "KickJS: Run Dev Server",
        "icon": "$(debug-start)"
      },
      {
        "command": "kickjs.build",
        "title": "KickJS: Build",
        "icon": "$(package)"
      },
      {
        "command": "kickjs.start",
        "title": "KickJS: Start (Production)",
        "icon": "$(rocket)"
      },
      {
        "command": "kickjs.generateModule",
        "title": "KickJS: Generate Module…",
        "icon": "$(new-folder)"
      },
      {
        "command": "kickjs.generateController",
        "title": "KickJS: Generate Controller…",
        "icon": "$(new-file)"
      },
      {
        "command": "kickjs.generateService",
        "title": "KickJS: Generate Service…",
        "icon": "$(new-file)"
      },
      {
        "command": "kickjs.generateScaffold",
        "title": "KickJS: Generate Scaffold…",
        "icon": "$(layers)"
      },
      {
        "command": "kickjs.addPackage",
        "title": "KickJS: Add Package…",
        "icon": "$(add)"
      },
      {
        "command": "kickjs.removeModule",
        "title": "KickJS: Remove Module…",
        "icon": "$(trash)"
      },
      {
        "command": "kickjs.generateAgentDocs",
        "title": "KickJS: Regenerate Agent Docs (AGENTS.md / CLAUDE.md / skills)…",
        "icon": "$(robot)"
      },
      {
        "command": "kickjs.mcpStart",
        "title": "KickJS: Start MCP Server",
        "icon": "$(plug)"
      },
      {
        "command": "kickjs.mcpInit",
        "title": "KickJS: Initialise MCP Config (.claude/)",
        "icon": "$(file-add)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "kickjs.connect",
          "when": "view == kickjs.health || view == kickjs.routes || view == kickjs.container",
          "group": "navigation@1"
        },
        {
          "command": "kickjs.refreshAll",
          "when": "view == kickjs.health || view == kickjs.routes || view == kickjs.container",
          "group": "navigation@2"
        }
      ],
      "commandPalette": [
        {
          "command": "kickjs.connect",
          "when": "kickjs.isKickProject"
        },
        {
          "command": "kickjs.inspect",
          "when": "kickjs.isKickProject"
        },
        {
          "command": "kickjs.showRoutes",
          "when": "kickjs.isKickProject"
        },
        {
          "command": "kickjs.showContainer",
          "when": "kickjs.isKickProject"
        },
        {
          "command": "kickjs.showMetrics",
          "when": "kickjs.isKickProject"
        },
        {
          "command": "kickjs.refreshAll",
          "when": "kickjs.isKickProject"
        },
        {
          "command": "kickjs.setToken",
          "when": "kickjs.isKickProject"
        },
        {
          "command": "kickjs.clearToken",
          "when": "kickjs.isKickProject"
        },
        {
          "command": "kickjs.dev",
          "when": "kickjs.isKickProject"
        },
        {
          "command": "kickjs.build",
          "when": "kickjs.isKickProject"
        },
        {
          "command": "kickjs.start",
          "when": "kickjs.isKickProject"
        },
        {
          "command": "kickjs.generateModule",
          "when": "kickjs.isKickProject"
        },
        {
          "command": "kickjs.generateController",
          "when": "kickjs.isKickProject"
        },
        {
          "command": "kickjs.generateService",
          "when": "kickjs.isKickProject"
        },
        {
          "command": "kickjs.generateScaffold",
          "when": "kickjs.isKickProject"
        },
        {
          "command": "kickjs.addPackage",
          "when": "kickjs.isKickProject"
        },
        {
          "command": "kickjs.removeModule",
          "when": "kickjs.isKickProject"
        },
        {
          "command": "kickjs.generateAgentDocs",
          "when": "kickjs.isKickProject"
        },
        {
          "command": "kickjs.mcpStart",
          "when": "kickjs.isKickProject"
        },
        {
          "command": "kickjs.mcpInit",
          "when": "kickjs.isKickProject"
        }
      ]
    },
    "configuration": {
      "title": "KickJS DevTools",
      "properties": {
        "kickjs.serverUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "URL of the running KickJS application"
        },
        "kickjs.debugPath": {
          "type": "string",
          "default": "/_debug",
          "description": "Base path for DevTools endpoints"
        },
        "kickjs.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Auto-refresh data every 30 seconds"
        },
        "kickjs.token": {
          "type": "string",
          "default": "",
          "description": "Optional DevTools auth token. Leave empty when the server runs the DevTools adapter with `secret: false` (auth disabled) — the extension probes + the tree views work without a token. When `secret` is auto-generated or explicitly set (printed as `[token: …]` in the startup console), paste it here OR run `KickJS: Set DevTools Token…` from the palette."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kickjs",
          "title": "KickJS",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "kickjs": [
        {
          "id": "kickjs.health",
          "name": "Health",
          "when": "kickjs.isKickProject"
        },
        {
          "id": "kickjs.routes",
          "name": "Routes",
          "when": "kickjs.isKickProject"
        },
        {
          "id": "kickjs.container",
          "name": "DI Container",
          "when": "kickjs.isKickProject"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "kickjs.health",
        "contents": "No KickJS app connected.\n\n[$(plug) Connect to App](command:kickjs.connect)\n\nThis probes common dev ports + your workspace `.env` for a running app.\n\n[Open settings](command:workbench.action.openSettings?%22kickjs.serverUrl%22)\n\nLearn more in the [DevTools docs](https://forinda.github.io/kick-js/guide/devtools).",
        "when": "!kickjs.connected"
      },
      {
        "view": "kickjs.routes",
        "contents": "No KickJS app connected.\n\n[$(plug) Connect to App](command:kickjs.connect)",
        "when": "!kickjs.connected"
      },
      {
        "view": "kickjs.container",
        "contents": "No KickJS app connected.\n\n[$(plug) Connect to App](command:kickjs.connect)",
        "when": "!kickjs.connected"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/vscode-extension"
  },
  "license": "MIT",
  "scripts": {
    "build": "pnpm build:icons && vite build",
    "build:icons": "node scripts/build-icons.mjs",
    "dev": "vite build --watch",
    "test": "vitest run --passWithNoTests",
    "package": "pnpm build && vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/node": "^25.9.1",
    "sharp": "^0.34.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "private": true
}
