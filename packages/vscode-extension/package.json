{
  "name": "kickjs-devtools",
  "displayName": "KickJS DevTools",
  "description": "VS Code extension for inspecting KickJS applications — routes, DI container, metrics, and health",
  "version": "5.0.1",
  "publisher": "forinda",
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "resources/icon.png",
  "categories": [
    "Other",
    "Debuggers"
  ],
  "keywords": [
    "kickjs",
    "devtools",
    "nodejs",
    "express",
    "typescript",
    "decorator"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:**/kick.config.ts",
    "workspaceContains:**/kick.config.js",
    "workspaceContains:**/kick.config.json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "kickjs.connect",
        "title": "KickJS: Connect to App…",
        "icon": "$(plug)"
      },
      {
        "command": "kickjs.inspect",
        "title": "KickJS: Inspect Running App"
      },
      {
        "command": "kickjs.showRoutes",
        "title": "KickJS: Show Routes"
      },
      {
        "command": "kickjs.showContainer",
        "title": "KickJS: Show DI Container"
      },
      {
        "command": "kickjs.showMetrics",
        "title": "KickJS: Show Metrics"
      },
      {
        "command": "kickjs.refreshAll",
        "title": "KickJS: Refresh All",
        "icon": "$(refresh)"
      },
      {
        "command": "kickjs.setToken",
        "title": "KickJS: Set DevTools Token…",
        "icon": "$(key)"
      },
      {
        "command": "kickjs.clearToken",
        "title": "KickJS: Clear DevTools Token"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "kickjs.connect",
          "when": "view == kickjs.health || view == kickjs.routes || view == kickjs.container",
          "group": "navigation@1"
        },
        {
          "command": "kickjs.refreshAll",
          "when": "view == kickjs.health || view == kickjs.routes || view == kickjs.container",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "KickJS DevTools",
      "properties": {
        "kickjs.serverUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "URL of the running KickJS application"
        },
        "kickjs.debugPath": {
          "type": "string",
          "default": "/_debug",
          "description": "Base path for DevTools endpoints"
        },
        "kickjs.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Auto-refresh data every 30 seconds"
        },
        "kickjs.token": {
          "type": "string",
          "default": "",
          "description": "Optional DevTools auth token. Leave empty when the server runs the DevTools adapter with `requireToken: false` (the default). When the server requires a token (printed as `[token: …]` in the startup console), paste it here OR run `KickJS: Set DevTools Token…` from the palette."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kickjs",
          "title": "KickJS",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "kickjs": [
        {
          "id": "kickjs.health",
          "name": "Health"
        },
        {
          "id": "kickjs.routes",
          "name": "Routes"
        },
        {
          "id": "kickjs.container",
          "name": "DI Container"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "kickjs.health",
        "contents": "No KickJS app connected.\n\n[$(plug) Connect to App](command:kickjs.connect)\n\nThis probes common dev ports + your workspace `.env` for a running app.\n\n[Open settings](command:workbench.action.openSettings?%22kickjs.serverUrl%22)\n\nLearn more in the [DevTools docs](https://forinda.github.io/kick-js/guide/devtools).",
        "when": "!kickjs.connected"
      },
      {
        "view": "kickjs.routes",
        "contents": "No KickJS app connected.\n\n[$(plug) Connect to App](command:kickjs.connect)",
        "when": "!kickjs.connected"
      },
      {
        "view": "kickjs.container",
        "contents": "No KickJS app connected.\n\n[$(plug) Connect to App](command:kickjs.connect)",
        "when": "!kickjs.connected"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/vscode-extension"
  },
  "license": "MIT",
  "scripts": {
    "build": "pnpm build:icons && vite build",
    "build:icons": "node scripts/build-icons.mjs",
    "dev": "vite build --watch",
    "test": "vitest run --passWithNoTests",
    "package": "pnpm build && vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^25.6.0",
    "sharp": "^0.34.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "private": true
}
