{
  "name": "@forinda/kickjs-multi-tenant",
  "version": "4.2.0",
  "description": "[DEPRECATED] Multi-tenancy helpers for KickJS — tenant resolution, scoped DI, and database routing — see https://forinda.github.io/kick-js/guide/multi-tenancy for the BYO replacement (going private in v4.1.2).",
  "keywords": [
    "kickjs",
    "nodejs",
    "typescript",
    "express",
    "decorators",
    "dependency-injection",
    "backend",
    "api",
    "framework",
    "multitenancy",
    "saas",
    "tenant",
    "subdomain",
    "isolation",
    "vite",
    "@forinda/kickjs",
    "@forinda/kickjs-auth",
    "@forinda/kickjs-cli",
    "@forinda/kickjs-devtools",
    "@forinda/kickjs-drizzle",
    "@forinda/kickjs-prisma",
    "@forinda/kickjs-queue",
    "@forinda/kickjs-swagger",
    "@forinda/kickjs-testing",
    "@forinda/kickjs-vite",
    "@forinda/kickjs-ws"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "wireit",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .wireit"
  },
  "wireit": {
    "build": {
      "command": "tsdown",
      "files": [
        "src/**/*.ts",
        "tsdown.config.ts",
        "tsconfig.json",
        "package.json"
      ],
      "output": [
        "dist/**"
      ],
      "dependencies": []
    }
  },
  "dependencies": {
    "@forinda/kickjs-devtools-kit": "workspace:*",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@forinda/kickjs": "workspace:*",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "express": "^5.1.0",
    "typescript": "^6.0.3",
    "unplugin-swc": "^1.5.7",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://forinda.github.io/kick-js/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/multi-tenant"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  },
  "peerDependencies": {
    "@forinda/kickjs": ">=2.3.0"
  },
  "peerDependenciesMeta": {},
  "deprecated": "Deprecated — going private in v4.1.2. Replaced by a BYO recipe using defineAdapter/definePlugin from @forinda/kickjs directly. See https://forinda.github.io/kick-js/guide/multi-tenancy for the migration."
}
