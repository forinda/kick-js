{
  "name": "@forinda/kickjs-multi-tenant",
  "version": "1.2.3",
  "description": "Multi-tenancy helpers for KickJS — tenant resolution, scoped DI, and database routing",
  "keywords": [
    "kickjs",
    "multi-tenant",
    "multitenancy",
    "saas",
    "tenant",
    "middleware",
    "typescript",
    "@forinda/kickjs-core",
    "@forinda/kickjs-http"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@forinda/kickjs-core": "workspace:*",
    "@forinda/kickjs-http": "workspace:*",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://forinda.github.io/kick-js/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/multi-tenant"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  }
}
