{
  "name": "@forinda/kickjs-mcp",
  "version": "7.0.1",
  "description": "Model Context Protocol server adapter for KickJS — expose @Controller endpoints as MCP tools",
  "keywords": [
    "kickjs",
    "nodejs",
    "typescript",
    "decorator-driven",
    "mcp",
    "model-context-protocol",
    "claude-tools",
    "claude-code",
    "anthropic",
    "tool-server",
    "tool-calling",
    "stdio",
    "cursor",
    "zed"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsgo --noEmit",
    "clean": "rm -rf dist .wireit"
  },
  "dependencies": {
    "@forinda/kickjs-schema": "workspace:*",
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^4.4.3",
    "@forinda/kickjs": ">=5.18.0"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": false
    }
  },
  "devDependencies": {
    "@forinda/kickjs": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@swc/core": "^1.15.43",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.0",
    "express": "^5.1.0",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://kickjs.app/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  }
}
