{
  "name": "@forinda/kickjs-otel",
  "version": "1.1.2",
  "description": "OpenTelemetry adapter for KickJS — automatic tracing, metrics, and export to any OTel backend",
  "keywords": [
    "kickjs",
    "nodejs",
    "typescript",
    "opentelemetry",
    "otel",
    "tracing",
    "metrics",
    "observability",
    "jaeger",
    "grafana",
    "datadog",
    "backend",
    "framework",
    "@forinda/kickjs-core",
    "@forinda/kickjs-http"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@forinda/kickjs-core": "workspace:*",
    "@forinda/kickjs-http": "workspace:*",
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "@opentelemetry/api": ">=1.4.0",
    "@opentelemetry/sdk-node": ">=0.50.0",
    "@opentelemetry/sdk-trace-base": ">=1.20.0",
    "@opentelemetry/sdk-metrics": ">=1.20.0",
    "@opentelemetry/semantic-conventions": ">=1.20.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/sdk-node": {
      "optional": true
    },
    "@opentelemetry/sdk-trace-base": {
      "optional": true
    },
    "@opentelemetry/sdk-metrics": {
      "optional": true
    }
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-base": "^1.30.1",
    "@opentelemetry/sdk-metrics": "^1.30.1",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@types/node": "^24.5.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://forinda.github.io/kick-js/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/otel"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  }
}
