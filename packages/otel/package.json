{
  "name": "@forinda/kickjs-otel",
  "version": "4.1.0",
  "description": "[DEPRECATED] OpenTelemetry adapter for KickJS — automatic tracing, metrics, and export to any OTel backend — see https://forinda.github.io/kick-js/guide/otel for the BYO replacement (going private in v4.1.2).",
  "keywords": [
    "kickjs",
    "nodejs",
    "typescript",
    "express",
    "decorators",
    "dependency-injection",
    "backend",
    "api",
    "framework",
    "opentelemetry",
    "tracing",
    "metrics",
    "observability",
    "jaeger",
    "grafana",
    "datadog",
    "prometheus",
    "vite",
    "@forinda/kickjs",
    "@forinda/kickjs-auth",
    "@forinda/kickjs-cli",
    "@forinda/kickjs-cron",
    "@forinda/kickjs-devtools",
    "@forinda/kickjs-drizzle",
    "@forinda/kickjs-graphql",
    "@forinda/kickjs-mailer",
    "@forinda/kickjs-multi-tenant",
    "@forinda/kickjs-notifications",
    "@forinda/kickjs-otel",
    "@forinda/kickjs-prisma",
    "@forinda/kickjs-queue",
    "@forinda/kickjs-swagger",
    "@forinda/kickjs-testing",
    "@forinda/kickjs-vite",
    "@forinda/kickjs-ws"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "wireit",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .wireit",
    "lint": "tsc --noEmit"
  },
  "wireit": {
    "build": {
      "command": "tsdown",
      "files": [
        "src/**/*.ts",
        "tsdown.config.ts",
        "tsconfig.json",
        "package.json"
      ],
      "output": [
        "dist/**"
      ],
      "dependencies": []
    }
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "@opentelemetry/api": ">=1.4.0",
    "@opentelemetry/sdk-node": ">=0.50.0",
    "@opentelemetry/sdk-trace-base": ">=1.20.0",
    "@opentelemetry/sdk-metrics": ">=1.20.0",
    "@opentelemetry/semantic-conventions": ">=1.20.0",
    "@forinda/kickjs": ">=2.3.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/sdk-node": {
      "optional": true
    },
    "@opentelemetry/sdk-trace-base": {
      "optional": true
    },
    "@opentelemetry/sdk-metrics": {
      "optional": true
    }
  },
  "devDependencies": {
    "@forinda/kickjs": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-metrics": "^2.7.0",
    "@opentelemetry/sdk-trace-base": "^2.7.0",
    "@opentelemetry/semantic-conventions": "^1.4.0",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://forinda.github.io/kick-js/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/otel"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  },
  "deprecated": "Deprecated — going private in v4.1.2. Replaced by a BYO recipe using defineAdapter/definePlugin from @forinda/kickjs directly. See https://forinda.github.io/kick-js/guide/otel for the migration."
}
