{
  "name": "@forinda/kickjs-otel",
  "version": "2.0.1",
  "description": "OpenTelemetry adapter for KickJS — automatic tracing, metrics, and export to any OTel backend",
  "keywords": [
    "kickjs",
    "nodejs",
    "typescript",
    "express",
    "decorators",
    "dependency-injection",
    "backend",
    "api",
    "framework",
    "opentelemetry",
    "tracing",
    "metrics",
    "observability",
    "jaeger",
    "grafana",
    "datadog",
    "prometheus",
    "@forinda/kickjs-core",
    "@forinda/kickjs-http",
    "@forinda/kickjs-config",
    "@forinda/kickjs-cli",
    "@forinda/kickjs-swagger",
    "@forinda/kickjs-testing",
    "@forinda/kickjs-prisma",
    "@forinda/kickjs-ws",
    "@forinda/kickjs-drizzle",
    "@forinda/kickjs-graphql",
    "@forinda/kickjs-auth",
    "@forinda/kickjs-cron",
    "@forinda/kickjs-mailer",
    "@forinda/kickjs-queue",
    "@forinda/kickjs-multi-tenant",
    "@forinda/kickjs-devtools",
    "@forinda/kickjs-notifications",
    "vite"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && pnpm build:types",
    "build:types": "tsc -p tsconfig.build.json",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@forinda/kickjs": "workspace:*",
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "@opentelemetry/api": ">=1.4.0",
    "@opentelemetry/sdk-node": ">=0.50.0",
    "@opentelemetry/sdk-trace-base": ">=1.20.0",
    "@opentelemetry/sdk-metrics": ">=1.20.0",
    "@opentelemetry/semantic-conventions": ">=1.20.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/sdk-node": {
      "optional": true
    },
    "@opentelemetry/sdk-trace-base": {
      "optional": true
    },
    "@opentelemetry/sdk-metrics": {
      "optional": true
    }
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.4.0",
    "@types/node": "^25.5.2",
    "typescript": "^5.9.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://forinda.github.io/kick-js/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/otel"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  }
}
