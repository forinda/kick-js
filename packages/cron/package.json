{
  "name": "@forinda/kickjs-cron",
  "version": "1.3.2",
  "description": "Production-grade cron job scheduling with pluggable backends for KickJS",
  "keywords": [
    "kickjs",
    "nodejs",
    "typescript",
    "express",
    "decorators",
    "dependency-injection",
    "backend",
    "api",
    "framework",
    "cron",
    "scheduler",
    "jobs",
    "croner",
    "node-cron",
    "recurring",
    "timezone",
    "@forinda/kickjs-core",
    "@forinda/kickjs-http",
    "@forinda/kickjs-config",
    "@forinda/kickjs-cli",
    "@forinda/kickjs-swagger",
    "@forinda/kickjs-testing",
    "@forinda/kickjs-prisma",
    "@forinda/kickjs-ws",
    "@forinda/kickjs-drizzle",
    "@forinda/kickjs-otel",
    "@forinda/kickjs-graphql",
    "@forinda/kickjs-auth",
    "@forinda/kickjs-mailer",
    "@forinda/kickjs-queue",
    "@forinda/kickjs-multi-tenant",
    "@forinda/kickjs-devtools",
    "@forinda/kickjs-notifications",
    "vite"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && pnpm build:types",
    "build:types": "tsc -p tsconfig.build.json",
    "dev": "vite build --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@forinda/kickjs-core": "workspace:*",
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "croner": "^9.0.0 || ^10.0.0"
  },
  "peerDependenciesMeta": {
    "croner": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "croner": "^10.0.1",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://forinda.github.io/kick-js/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/cron"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  }
}
