{
  "name": "@forinda/kickjs-cron",
  "version": "1.2.6",
  "description": "Production-grade cron job scheduling with pluggable backends for KickJS",
  "keywords": [
    "kickjs",
    "cron",
    "scheduler",
    "jobs",
    "croner",
    "node-cron",
    "typescript",
    "decorators",
    "production",
    "timezone"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@forinda/kickjs-core": "workspace:*",
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "croner": "^9.0.0 || ^10.0.0"
  },
  "peerDependenciesMeta": {
    "croner": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "croner": "^10.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://forinda.github.io/kick-js/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/cron"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  }
}
