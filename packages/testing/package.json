{
  "name": "@forinda/kickjs-testing",
  "version": "1.2.13",
  "description": "Test utilities, TestModule builder, and helpers for KickJS applications",
  "keywords": [
    "kickjs",
    "nodejs",
    "typescript",
    "express",
    "decorators",
    "dependency-injection",
    "backend",
    "api",
    "framework",
    "testing",
    "test-utilities",
    "vitest",
    "unit-testing",
    "integration-testing",
    "@forinda/kickjs-core",
    "@forinda/kickjs-http",
    "@forinda/kickjs-config",
    "@forinda/kickjs-cli",
    "@forinda/kickjs-swagger",
    "@forinda/kickjs-testing",
    "@forinda/kickjs-prisma"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@forinda/kickjs-core": "workspace:*",
    "@forinda/kickjs-http": "workspace:*"
  },
  "peerDependencies": {
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@swc/core": "^1.15.21",
    "@types/express": "^5.0.6",
    "@types/node": "^24.5.2",
    "express": "^5.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://forinda.github.io/kick-js/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/testing"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  }
}
