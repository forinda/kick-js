{
  "name": "@forinda/kickjs-notifications",
  "version": "2.2.0",
  "description": "Multi-channel notifications for KickJS — email, Slack, Discord, webhook, custom",
  "keywords": [
    "kickjs",
    "nodejs",
    "typescript",
    "express",
    "decorators",
    "dependency-injection",
    "backend",
    "api",
    "framework",
    "slack",
    "discord",
    "webhook",
    "push",
    "multi-channel",
    "alerts",
    "@forinda/kickjs-core",
    "@forinda/kickjs-http",
    "@forinda/kickjs-config",
    "@forinda/kickjs-cli",
    "@forinda/kickjs-swagger",
    "@forinda/kickjs-testing",
    "@forinda/kickjs-prisma",
    "@forinda/kickjs-ws",
    "@forinda/kickjs-drizzle",
    "@forinda/kickjs-otel",
    "@forinda/kickjs-graphql",
    "@forinda/kickjs-auth",
    "@forinda/kickjs-cron",
    "@forinda/kickjs-mailer",
    "@forinda/kickjs-queue",
    "@forinda/kickjs-multi-tenant",
    "@forinda/kickjs-devtools",
    "vite"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "wireit",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .wireit"
  },
  "wireit": {
    "build": {
      "command": "tsdown",
      "files": [
        "src/**/*.ts",
        "tsdown.config.ts",
        "tsconfig.json",
        "package.json"
      ],
      "output": [
        "dist/**"
      ],
      "dependencies": [
        "../core:build"
      ]
    }
  },
  "dependencies": {
    "@forinda/kickjs": "workspace:*",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://forinda.github.io/kick-js/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/notifications"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  }
}
