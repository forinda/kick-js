{
  "name": "@forinda/kickjs-lint",
  "version": "5.2.3",
  "description": "Lint rules for KickJS — DI token convention, plugin/adapter naming, and other framework conventions",
  "keywords": [
    "kickjs",
    "nodejs",
    "typescript",
    "lint",
    "kickjs-lint",
    "di-token-convention",
    "static-analysis",
    "naming-convention",
    "framework-lint"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "bin": {
    "kick-lint": "bin.mjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./rules": {
      "import": "./dist/rules.mjs",
      "types": "./dist/rules.d.mts"
    }
  },
  "files": [
    "dist",
    "bin.mjs"
  ],
  "scripts": {
    "build": "wireit",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "typecheck": "tsgo --noEmit",
    "clean": "rm -rf dist .wireit"
  },
  "wireit": {
    "build": {
      "command": "tsdown",
      "files": [
        "src/**/*.ts",
        "tsdown.config.ts",
        "tsconfig.json",
        "package.json"
      ],
      "output": [
        "dist/**"
      ]
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^25.8.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://forinda.github.io/kick-js/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/lint"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  }
}
