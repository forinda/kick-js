{
  "name": "@forinda/kickjs-cli",
  "version": "2.3.2",
  "description": "CLI for KickJS — project scaffolding, DDD module generation, dev/build/start",
  "keywords": [
    "kickjs",
    "nodejs",
    "typescript",
    "express",
    "decorators",
    "dependency-injection",
    "backend",
    "api",
    "framework",
    "scaffolding",
    "code-generator",
    "project-generator",
    "ddd",
    "domain-driven-design",
    "vite",
    "hmr",
    "@forinda/kickjs",
    "@forinda/kickjs-auth",
    "@forinda/kickjs-cli",
    "@forinda/kickjs-config",
    "@forinda/kickjs-core",
    "@forinda/kickjs-cron",
    "@forinda/kickjs-devtools",
    "@forinda/kickjs-drizzle",
    "@forinda/kickjs-graphql",
    "@forinda/kickjs-http",
    "@forinda/kickjs-mailer",
    "@forinda/kickjs-multi-tenant",
    "@forinda/kickjs-notifications",
    "@forinda/kickjs-otel",
    "@forinda/kickjs-prisma",
    "@forinda/kickjs-queue",
    "@forinda/kickjs-swagger",
    "@forinda/kickjs-testing",
    "@forinda/kickjs-vite",
    "@forinda/kickjs-ws"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "bin": {
    "kick": "bin.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "bin.js",
    "dist"
  ],
  "scripts": {
    "build": "wireit",
    "dev": "tsdown --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .wireit",
    "lint": "tsc --noEmit"
  },
  "wireit": {
    "build": {
      "command": "tsdown",
      "files": [
        "src/**/*.ts",
        "tsdown.config.ts",
        "tsconfig.json",
        "package.json"
      ],
      "output": [
        "dist/**"
      ],
      "dependencies": [
        "../core:build",
        "../http:build"
      ]
    }
  },
  "dependencies": {
    "commander": "^14.0.3",
    "pluralize": "^8.0.0"
  },
  "devDependencies": {
    "@forinda/kickjs-ai": "workspace:*",
    "@swc/core": "^1.15.21",
    "@types/node": "^25.0.0",
    "@types/pluralize": "^0.0.33",
    "typescript": "^5.9.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://forinda.github.io/kick-js/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  }
}
