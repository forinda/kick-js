{
  "name": "@forinda/kickjs-cli",
  "version": "6.2.0-alpha.0",
  "description": "CLI for KickJS — project scaffolding, DDD module generation, dev/build/start",
  "keywords": [
    "kickjs",
    "nodejs",
    "typescript",
    "decorator-driven",
    "cli-tool",
    "scaffolding",
    "code-generator",
    "project-generator",
    "ddd-generator",
    "domain-driven-design",
    "hmr"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "bin": {
    "kick": "bin.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "bin.js",
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsgo --noEmit",
    "clean": "rm -rf dist .wireit"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "@forinda/kickjs": "workspace:*",
    "@forinda/kickjs-cli-kit": "workspace:*",
    "@forinda/kickjs-db": "workspace:*",
    "commander": "^15.0.0",
    "glob": "^13.0.6",
    "jiti": "^2.7.0",
    "oxc-parser": "^0.135.0",
    "oxfmt": "^0.54.0",
    "picocolors": "^1.1.1",
    "pluralize": "^8.0.0"
  },
  "devDependencies": {
    "@forinda/kickjs-ai": "workspace:*",
    "@swc/core": "^1.15.40",
    "@types/node": "^25.9.2",
    "@types/pg": "^8.11.10",
    "@types/pluralize": "^0.0.33",
    "pg": "^8.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://forinda.github.io/kick-js/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  }
}
