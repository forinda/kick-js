{
  "name": "@forinda/kickjs-cli",
  "version": "1.4.0",
  "description": "CLI for KickJS — project scaffolding, DDD module generation, dev/build/start",
  "keywords": [
    "kickjs",
    "nodejs",
    "typescript",
    "express",
    "decorators",
    "dependency-injection",
    "backend",
    "api",
    "framework",
    "scaffolding",
    "code-generator",
    "project-generator",
    "ddd",
    "domain-driven-design",
    "vite",
    "hmr",
    "@forinda/kickjs-core",
    "@forinda/kickjs-http",
    "@forinda/kickjs-config",
    "@forinda/kickjs-swagger",
    "@forinda/kickjs-testing",
    "@forinda/kickjs-prisma",
    "@forinda/kickjs-ws",
    "@forinda/kickjs-drizzle",
    "@forinda/kickjs-otel",
    "@forinda/kickjs-graphql",
    "@forinda/kickjs-auth",
    "@forinda/kickjs-cron",
    "@forinda/kickjs-mailer",
    "@forinda/kickjs-queue",
    "@forinda/kickjs-multi-tenant",
    "@forinda/kickjs-devtools",
    "@forinda/kickjs-notifications"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "kick": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && pnpm build:types",
    "build:types": "tsc -p tsconfig.build.json",
    "dev": "vite build --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@swc/core": "^1.7.28",
    "@types/node": "^25.0.0",
    "vite": "^8.0.2",
    "typescript": "^5.9.2",
    "vitest": "^4.1.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://forinda.github.io/kick-js/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  }
}
