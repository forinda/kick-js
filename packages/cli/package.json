{
  "name": "@forinda/kickjs-cli",
  "version": "0.4.0",
  "description": "CLI for KickJS — project scaffolding, DDD module generation, dev/build/start",
  "keywords": [
    "kickjs",
    "nodejs",
    "typescript",
    "express",
    "decorators",
    "dependency-injection",
    "backend",
    "api",
    "framework",
    "cli",
    "scaffolding",
    "code-generator",
    "project-generator",
    "ddd",
    "domain-driven-design"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "kick": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@swc/core": "^1.7.28",
    "@types/node": "^24.5.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://forinda.github.io/kick-js/"
}
