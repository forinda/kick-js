{
  "name": "@forinda/kickjs-db-mysql",
  "version": "3.0.0-alpha.0",
  "description": "mysql2 adapter for @forinda/kickjs-db — MigrationAdapter + Kysely MysqlDialect (MySQL 8.0+)",
  "keywords": [
    "kickjs",
    "nodejs",
    "typescript",
    "mysql",
    "mysql2",
    "mysql-8",
    "kysely-dialect",
    "kysely",
    "orm-adapter",
    "migrations"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "wireit",
    "dev": "tsdown --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsgo --noEmit",
    "clean": "rm -rf dist .wireit",
    "lint": "tsc --noEmit"
  },
  "wireit": {
    "build": {
      "command": "tsdown",
      "files": [
        "src/**/*.ts",
        "tsdown.config.ts",
        "tsconfig.json",
        "package.json"
      ],
      "output": [
        "dist/**"
      ],
      "dependencies": []
    }
  },
  "dependencies": {},
  "peerDependencies": {
    "@forinda/kickjs-db": "workspace:^",
    "kysely": "0.29.2",
    "mysql2": ">=3.0.0"
  },
  "devDependencies": {
    "@forinda/kickjs": "workspace:*",
    "@forinda/kickjs-db": "workspace:*",
    "@types/node": "^25.9.1",
    "kysely": "^0.29.2",
    "mysql2": "^3.22.4",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://forinda.github.io/kick-js/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/db-mysql"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  }
}
