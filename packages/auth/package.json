{
  "name": "@forinda/kickjs-auth",
  "version": "6.0.1",
  "private": true,
  "description": "Pluggable authentication for KickJS — JWT, API key, and custom strategies",
  "keywords": [
    "kickjs",
    "nodejs",
    "typescript",
    "decorator-driven",
    "authentication",
    "authorization",
    "jwt",
    "api-key",
    "oauth",
    "rbac",
    "roles",
    "guards",
    "passport-alternative",
    "decorator-auth"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "typecheck": "tsgo --noEmit",
    "clean": "rm -rf dist .wireit"
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "@forinda/kickjs": ">=5.18.0",
    "jsonwebtoken": "^9.0.0",
    "argon2": ">=0.31.0",
    "bcryptjs": ">=2.4.0",
    "bcrypt": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "jsonwebtoken": {
      "optional": true
    },
    "argon2": {
      "optional": true
    },
    "bcryptjs": {
      "optional": true
    },
    "bcrypt": {
      "optional": true
    }
  },
  "devDependencies": {
    "@forinda/kickjs": "workspace:*",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^26.1.0",
    "jsonwebtoken": "^9.0.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://kickjs.app/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/auth"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  }
}
