{
  "name": "@forinda/kickjs-auth",
  "version": "5.2.3",
  "description": "Pluggable authentication for KickJS — JWT, API key, and custom strategies",
  "keywords": [
    "kickjs",
    "nodejs",
    "typescript",
    "decorator-driven",
    "authentication",
    "authorization",
    "jwt",
    "api-key",
    "oauth",
    "rbac",
    "roles",
    "guards",
    "passport-alternative",
    "decorator-auth"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "wireit",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .wireit"
  },
  "wireit": {
    "build": {
      "command": "tsdown",
      "files": [
        "src/**/*.ts",
        "tsdown.config.ts",
        "tsconfig.json",
        "package.json"
      ],
      "output": [
        "dist/**"
      ],
      "dependencies": []
    }
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "@forinda/kickjs": ">=2.3.0",
    "jsonwebtoken": "^9.0.0",
    "argon2": ">=0.31.0",
    "bcryptjs": ">=2.4.0",
    "bcrypt": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "jsonwebtoken": {
      "optional": true
    },
    "argon2": {
      "optional": true
    },
    "bcryptjs": {
      "optional": true
    },
    "bcrypt": {
      "optional": true
    }
  },
  "devDependencies": {
    "@forinda/kickjs": "workspace:*",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^25.8.0",
    "jsonwebtoken": "^9.0.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://forinda.github.io/kick-js/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/auth"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  }
}
