{
  "name": "@forinda/kickjs-http",
  "version": "3.0.1",
  "private": true,
  "deprecated": "@forinda/kickjs-http has been merged into @forinda/kickjs. Import from '@forinda/kickjs' instead. This package is no longer published.",
  "description": "DEPRECATED — merged into @forinda/kickjs. This package exists only as an internal build dependency.",
  "keywords": [
    "kickjs",
    "nodejs",
    "typescript",
    "express",
    "decorators",
    "dependency-injection",
    "backend",
    "api",
    "framework",
    "express5",
    "middleware",
    "routing",
    "rest-api",
    "request-context",
    "upload",
    "query-parsing",
    "rate-limiting",
    "cors",
    "helmet",
    "vite",
    "@forinda/kickjs",
    "@forinda/kickjs-auth",
    "@forinda/kickjs-cli",
    "@forinda/kickjs-config",
    "@forinda/kickjs-core",
    "@forinda/kickjs-cron",
    "@forinda/kickjs-devtools",
    "@forinda/kickjs-drizzle",
    "@forinda/kickjs-graphql",
    "@forinda/kickjs-http",
    "@forinda/kickjs-mailer",
    "@forinda/kickjs-multi-tenant",
    "@forinda/kickjs-notifications",
    "@forinda/kickjs-otel",
    "@forinda/kickjs-prisma",
    "@forinda/kickjs-queue",
    "@forinda/kickjs-swagger",
    "@forinda/kickjs-testing",
    "@forinda/kickjs-vite",
    "@forinda/kickjs-ws"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./application": {
      "import": "./dist/application.mjs",
      "types": "./dist/application.d.mts"
    },
    "./bootstrap": {
      "import": "./dist/bootstrap.mjs",
      "types": "./dist/bootstrap.d.mts"
    },
    "./context": {
      "import": "./dist/context.mjs",
      "types": "./dist/context.d.mts"
    },
    "./router": {
      "import": "./dist/router-builder.mjs",
      "types": "./dist/router-builder.d.mts"
    },
    "./middleware/csrf": {
      "import": "./dist/middleware/csrf.mjs",
      "types": "./dist/middleware/csrf.d.mts"
    },
    "./middleware/rate-limit": {
      "import": "./dist/middleware/rate-limit.mjs",
      "types": "./dist/middleware/rate-limit.d.mts"
    },
    "./middleware/session": {
      "import": "./dist/middleware/session.mjs",
      "types": "./dist/middleware/session.d.mts"
    },
    "./middleware/upload": {
      "import": "./dist/middleware/upload.mjs",
      "types": "./dist/middleware/upload.d.mts"
    },
    "./middleware/validate": {
      "import": "./dist/middleware/validate.mjs",
      "types": "./dist/middleware/validate.d.mts"
    },
    "./middleware/request-id": {
      "import": "./dist/middleware/request-id.mjs",
      "types": "./dist/middleware/request-id.d.mts"
    },
    "./middleware/error-handler": {
      "import": "./dist/middleware/error-handler.mjs",
      "types": "./dist/middleware/error-handler.d.mts"
    },
    "./query": {
      "import": "./dist/query/index.mjs",
      "types": "./dist/query/index.d.mts"
    },
    "./views": {
      "import": "./dist/middleware/views.mjs",
      "types": "./dist/middleware/views.d.mts"
    },
    "./spa": {
      "import": "./dist/middleware/spa.mjs",
      "types": "./dist/middleware/spa.d.mts"
    },
    "./middleware/request-logger": {
      "import": "./dist/middleware/request-logger.mjs",
      "types": "./dist/middleware/request-logger.d.mts"
    },
    "./middleware/helmet": {
      "import": "./dist/middleware/helmet.mjs",
      "types": "./dist/middleware/helmet.d.mts"
    },
    "./middleware/cors": {
      "import": "./dist/middleware/cors.mjs",
      "types": "./dist/middleware/cors.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "wireit",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .wireit",
    "lint": "tsc --noEmit"
  },
  "wireit": {
    "build": {
      "command": "tsdown",
      "files": [
        "src/**/*.ts",
        "tsdown.config.ts",
        "tsconfig.json",
        "package.json"
      ],
      "output": [
        "dist/**"
      ],
      "dependencies": [
        "../core:build"
      ]
    }
  },
  "dependencies": {
    "@forinda/kickjs-core": "workspace:*",
    "cookie-parser": "^1.4.7",
    "multer": "^2.1.1",
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@swc/core": "^1.15.21",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.0.0",
    "express": "^5.1.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://forinda.github.io/kick-js/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/http"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  }
}
