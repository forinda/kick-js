{
  "name": "@forinda/kickjs-http",
  "version": "1.7.0",
  "description": "Express 5 integration, router builder, RequestContext, and middleware for KickJS",
  "keywords": [
    "kickjs",
    "nodejs",
    "typescript",
    "express",
    "decorators",
    "dependency-injection",
    "backend",
    "api",
    "framework",
    "express5",
    "middleware",
    "routing",
    "rest-api",
    "request-context",
    "upload",
    "query-parsing",
    "rate-limiting",
    "cors",
    "helmet",
    "@forinda/kickjs-core",
    "@forinda/kickjs-config",
    "@forinda/kickjs-cli",
    "@forinda/kickjs-swagger",
    "@forinda/kickjs-testing",
    "@forinda/kickjs-prisma",
    "@forinda/kickjs-ws",
    "@forinda/kickjs-drizzle",
    "@forinda/kickjs-otel",
    "@forinda/kickjs-graphql",
    "@forinda/kickjs-auth",
    "@forinda/kickjs-cron",
    "@forinda/kickjs-mailer",
    "@forinda/kickjs-queue",
    "@forinda/kickjs-multi-tenant",
    "@forinda/kickjs-devtools",
    "@forinda/kickjs-notifications",
    "vite"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./application": {
      "import": "./dist/application.js",
      "types": "./dist/application.d.ts"
    },
    "./bootstrap": {
      "import": "./dist/bootstrap.js",
      "types": "./dist/bootstrap.d.ts"
    },
    "./context": {
      "import": "./dist/context.js",
      "types": "./dist/context.d.ts"
    },
    "./router": {
      "import": "./dist/router-builder.js",
      "types": "./dist/router-builder.d.ts"
    },
    "./middleware/csrf": {
      "import": "./dist/middleware/csrf.js",
      "types": "./dist/middleware/csrf.d.ts"
    },
    "./middleware/rate-limit": {
      "import": "./dist/middleware/rate-limit.js",
      "types": "./dist/middleware/rate-limit.d.ts"
    },
    "./middleware/session": {
      "import": "./dist/middleware/session.js",
      "types": "./dist/middleware/session.d.ts"
    },
    "./middleware/upload": {
      "import": "./dist/middleware/upload.js",
      "types": "./dist/middleware/upload.d.ts"
    },
    "./middleware/validate": {
      "import": "./dist/middleware/validate.js",
      "types": "./dist/middleware/validate.d.ts"
    },
    "./middleware/request-id": {
      "import": "./dist/middleware/request-id.js",
      "types": "./dist/middleware/request-id.d.ts"
    },
    "./middleware/error-handler": {
      "import": "./dist/middleware/error-handler.js",
      "types": "./dist/middleware/error-handler.d.ts"
    },
    "./query": {
      "import": "./dist/query/index.js",
      "types": "./dist/query/index.d.ts"
    },
    "./views": {
      "import": "./dist/middleware/views.js",
      "types": "./dist/middleware/views.d.ts"
    },
    "./spa": {
      "import": "./dist/middleware/spa.js",
      "types": "./dist/middleware/spa.d.ts"
    },
    "./middleware/request-logger": {
      "import": "./dist/middleware/request-logger.js",
      "types": "./dist/middleware/request-logger.d.ts"
    },
    "./middleware/helmet": {
      "import": "./dist/middleware/helmet.js",
      "types": "./dist/middleware/helmet.d.ts"
    },
    "./middleware/cors": {
      "import": "./dist/middleware/cors.js",
      "types": "./dist/middleware/cors.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && pnpm build:types",
    "build:types": "tsc -p tsconfig.build.json",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@forinda/kickjs-core": "workspace:*",
    "cookie-parser": "^1.4.7",
    "multer": "^2.1.1",
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@swc/core": "^1.7.28",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.0.0",
    "express": "^5.1.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://forinda.github.io/kick-js/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/http"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  }
}
