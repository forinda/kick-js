{
  "name": "@forinda/kickjs-queue",
  "version": "7.0.1",
  "description": "BullMQ queue/worker adapter with decorator-driven job processing for KickJS",
  "keywords": [
    "kickjs",
    "nodejs",
    "typescript",
    "decorator-driven",
    "bullmq",
    "ioredis",
    "background-jobs",
    "worker",
    "redis-queue",
    "queue",
    "decorator-jobs",
    "job-scheduler"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsgo --noEmit",
    "clean": "rm -rf dist .wireit"
  },
  "dependencies": {
    "@forinda/kickjs-devtools-kit": "workspace:*",
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "bullmq": ">=5.0.0",
    "ioredis": ">=5.0.0",
    "@forinda/kickjs": ">=5.18.0"
  },
  "devDependencies": {
    "@forinda/kickjs": "workspace:*",
    "@types/node": "^25.9.2",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://kickjs.app/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/queue"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  },
  "peerDependenciesMeta": {}
}
