{
  "name": "@forinda/kickjs-queue",
  "version": "1.2.6",
  "description": "BullMQ queue/worker adapter with decorator-driven job processing for KickJS",
  "keywords": [
    "kickjs",
    "nodejs",
    "typescript",
    "queue",
    "worker",
    "bullmq",
    "jobs",
    "background-jobs",
    "adapter",
    "@forinda/kickjs-core"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@forinda/kickjs-core": "workspace:*",
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "bullmq": ">=5.0.0",
    "ioredis": ">=5.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://forinda.github.io/kick-js/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/queue"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  }
}
