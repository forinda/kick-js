{
  "name": "@forinda/kickjs",
  "version": "3.2.0",
  "description": "A production-grade, decorator-driven Node.js framework built on Express 5 and TypeScript.",
  "keywords": [
    "kickjs",
    "nodejs",
    "typescript",
    "express",
    "decorators",
    "dependency-injection",
    "backend",
    "api",
    "framework",
    "ddd",
    "cqrs",
    "rest",
    "vite",
    "zod",
    "swagger",
    "openapi",
    "@forinda/kickjs",
    "@forinda/kickjs-auth",
    "@forinda/kickjs-cli",
    "@forinda/kickjs-cron",
    "@forinda/kickjs-devtools",
    "@forinda/kickjs-drizzle",
    "@forinda/kickjs-graphql",
    "@forinda/kickjs-mailer",
    "@forinda/kickjs-multi-tenant",
    "@forinda/kickjs-notifications",
    "@forinda/kickjs-otel",
    "@forinda/kickjs-prisma",
    "@forinda/kickjs-queue",
    "@forinda/kickjs-swagger",
    "@forinda/kickjs-testing",
    "@forinda/kickjs-vite",
    "@forinda/kickjs-ws"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./adapter": {
      "import": "./dist/core/adapter.mjs",
      "types": "./dist/core/adapter.d.mts"
    },
    "./container": {
      "import": "./dist/core/container.mjs",
      "types": "./dist/core/container.d.mts"
    },
    "./decorators": {
      "import": "./dist/core/decorators.mjs",
      "types": "./dist/core/decorators.d.mts"
    },
    "./logger": {
      "import": "./dist/core/logger.mjs",
      "types": "./dist/core/logger.d.mts"
    },
    "./errors": {
      "import": "./dist/core/errors.mjs",
      "types": "./dist/core/errors.d.mts"
    },
    "./reactivity": {
      "import": "./dist/core/reactivity.mjs",
      "types": "./dist/core/reactivity.d.mts"
    },
    "./middleware/helmet": {
      "import": "./dist/http/middleware/helmet.mjs",
      "types": "./dist/http/middleware/helmet.d.mts"
    },
    "./middleware/cors": {
      "import": "./dist/http/middleware/cors.mjs",
      "types": "./dist/http/middleware/cors.d.mts"
    },
    "./middleware/csrf": {
      "import": "./dist/http/middleware/csrf.mjs",
      "types": "./dist/http/middleware/csrf.d.mts"
    },
    "./middleware/rate-limit": {
      "import": "./dist/http/middleware/rate-limit.mjs",
      "types": "./dist/http/middleware/rate-limit.d.mts"
    },
    "./middleware/request-id": {
      "import": "./dist/http/middleware/request-id.mjs",
      "types": "./dist/http/middleware/request-id.d.mts"
    },
    "./middleware/request-logger": {
      "import": "./dist/http/middleware/request-logger.mjs",
      "types": "./dist/http/middleware/request-logger.d.mts"
    },
    "./query": {
      "import": "./dist/http/query/index.mjs",
      "types": "./dist/http/query/index.d.mts"
    },
    "./views": {
      "import": "./dist/http/middleware/views.mjs",
      "types": "./dist/http/middleware/views.d.mts"
    },
    "./spa": {
      "import": "./dist/http/middleware/spa.mjs",
      "types": "./dist/http/middleware/spa.d.mts"
    },
    "./config": {
      "import": "./dist/config/index.mjs",
      "types": "./dist/config/index.d.mts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "wireit",
    "dev": "tsdown --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .wireit"
  },
  "wireit": {
    "build": {
      "command": "tsdown",
      "files": [
        "src/**/*.ts",
        "tsdown.config.ts",
        "tsconfig.json",
        "package.json"
      ],
      "output": [
        "dist/**"
      ]
    }
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "multer": "^2.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "dotenv": "^17.0.0",
    "express": "^5.1.0"
  },
  "peerDependenciesMeta": {
    "dotenv": {
      "optional": true
    }
  },
  "devDependencies": {
    "@swc/core": "^1.15.30",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://forinda.github.io/kick-js/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/kickjs"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  }
}
