{
  "name": "@forinda/kickjs-ws",
  "version": "7.0.0",
  "description": "WebSocket support with decorators, namespaces, rooms, and DI integration for KickJS",
  "keywords": [
    "kickjs",
    "nodejs",
    "typescript",
    "decorator-driven",
    "websocket",
    "ws",
    "realtime",
    "rooms",
    "namespaces",
    "heartbeat",
    "decorator-websocket"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsgo --noEmit",
    "clean": "rm -rf dist .wireit"
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@forinda/kickjs": "workspace:*",
    "@swc/core": "^1.15.41",
    "@types/node": "^25.9.2",
    "@types/ws": "^8.18.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "ws": "^8.21.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://forinda.github.io/kick-js/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/ws"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  },
  "peerDependencies": {
    "@forinda/kickjs": ">=5.18.0",
    "ws": "^8.0.0"
  },
  "peerDependenciesMeta": {}
}
