{
  "name": "@forinda/kickjs-graphql",
  "version": "2.2.0",
  "description": "GraphQL module for KickJS with decorator-based resolvers, schema generation, and playground",
  "keywords": [
    "kickjs",
    "nodejs",
    "typescript",
    "express",
    "decorators",
    "dependency-injection",
    "backend",
    "api",
    "framework",
    "graphql",
    "graphiql",
    "resolver",
    "schema",
    "apollo",
    "query",
    "mutation",
    "@forinda/kickjs-core",
    "@forinda/kickjs-http",
    "@forinda/kickjs-config",
    "@forinda/kickjs-cli",
    "@forinda/kickjs-swagger",
    "@forinda/kickjs-testing",
    "@forinda/kickjs-prisma",
    "@forinda/kickjs-ws",
    "@forinda/kickjs-drizzle",
    "@forinda/kickjs-otel",
    "@forinda/kickjs-auth",
    "@forinda/kickjs-cron",
    "@forinda/kickjs-mailer",
    "@forinda/kickjs-queue",
    "@forinda/kickjs-multi-tenant",
    "@forinda/kickjs-devtools",
    "@forinda/kickjs-notifications",
    "vite"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "wireit",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .wireit"
  },
  "wireit": {
    "build": {
      "command": "tsdown",
      "files": [
        "src/**/*.ts",
        "tsdown.config.ts",
        "tsconfig.json",
        "package.json"
      ],
      "output": [
        "dist/**"
      ],
      "dependencies": [
        "../core:build",
        "../http:build"
      ]
    }
  },
  "dependencies": {
    "@forinda/kickjs": "workspace:*",
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "graphql": ">=16.0.0"
  },
  "devDependencies": {
    "graphql": "^16.13.2",
    "@types/node": "^25.0.0",
    "typescript": "^5.9.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://forinda.github.io/kick-js/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/graphql"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  }
}
