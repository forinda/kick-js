{
  "name": "@forinda/kickjs-graphql",
  "version": "1.2.2",
  "description": "GraphQL module for KickJS with decorator-based resolvers, schema generation, and playground",
  "keywords": [
    "kickjs",
    "graphql",
    "decorators",
    "resolver",
    "schema",
    "api",
    "typescript",
    "@forinda/kickjs-core",
    "@forinda/kickjs-http"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@forinda/kickjs-core": "workspace:*",
    "@forinda/kickjs-http": "workspace:*",
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "graphql": ">=16.0.0"
  },
  "devDependencies": {
    "graphql": "^16.11.0",
    "@types/node": "^24.5.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://forinda.github.io/kick-js/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/graphql"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  }
}
