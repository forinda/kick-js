{
  "name": "@forinda/kickjs-ai",
  "version": "7.0.1",
  "description": "AI runtime for KickJS — providers, @AiTool decorator, streaming, RAG, and agent loops",
  "keywords": [
    "kickjs",
    "nodejs",
    "typescript",
    "decorator-driven",
    "ai",
    "llm",
    "openai",
    "anthropic",
    "gemini",
    "ollama",
    "tool-calling",
    "streaming",
    "rag",
    "vector-search",
    "agent",
    "embeddings",
    "qdrant",
    "pinecone",
    "pgvector",
    "chat-memory"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsgo --noEmit",
    "clean": "rm -rf dist .wireit"
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "zod": "^4.4.3",
    "@forinda/kickjs": ">=5.18.0"
  },
  "devDependencies": {
    "@forinda/kickjs": "workspace:*",
    "@swc/core": "^1.15.46",
    "@types/node": "^26.1.1",
    "typescript": "^6.0.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://kickjs.app/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/ai"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  },
  "peerDependenciesMeta": {}
}
