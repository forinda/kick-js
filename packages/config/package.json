{
  "name": "@forinda/kickjs-config",
  "version": "2.2.3",
  "description": "DEPRECATED — moved into @forinda/kickjs. This package is a thin re-export shim and will be removed in v3.",
  "deprecated": "@forinda/kickjs-config has been merged into @forinda/kickjs. Import { defineEnv, loadEnv, ConfigService } from '@forinda/kickjs' instead, and { envWatchPlugin } from '@forinda/kickjs-vite'. This shim will be removed in v3.",
  "keywords": [
    "kickjs",
    "nodejs",
    "typescript",
    "express",
    "decorators",
    "dependency-injection",
    "backend",
    "api",
    "framework",
    "zod",
    "env",
    "environment-variables",
    "dotenv",
    "validation",
    "configuration",
    "vite",
    "@forinda/kickjs",
    "@forinda/kickjs-auth",
    "@forinda/kickjs-cli",
    "@forinda/kickjs-config",
    "@forinda/kickjs-core",
    "@forinda/kickjs-cron",
    "@forinda/kickjs-devtools",
    "@forinda/kickjs-drizzle",
    "@forinda/kickjs-graphql",
    "@forinda/kickjs-http",
    "@forinda/kickjs-mailer",
    "@forinda/kickjs-multi-tenant",
    "@forinda/kickjs-notifications",
    "@forinda/kickjs-otel",
    "@forinda/kickjs-prisma",
    "@forinda/kickjs-queue",
    "@forinda/kickjs-swagger",
    "@forinda/kickjs-testing",
    "@forinda/kickjs-vite",
    "@forinda/kickjs-ws"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "wireit",
    "dev": "tsdown --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .wireit",
    "lint": "tsc --noEmit"
  },
  "wireit": {
    "build": {
      "command": "tsdown",
      "files": [
        "src/**/*.ts",
        "tsdown.config.ts",
        "tsconfig.json",
        "package.json"
      ],
      "output": [
        "dist/**"
      ]
    }
  },
  "dependencies": {
    "@forinda/kickjs": "workspace:*"
  },
  "peerDependencies": {
    "vite": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@swc/core": "^1.15.24",
    "@types/node": "^25.5.2",
    "typescript": "^5.9.2",
    "vitest": "^4.1.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://forinda.github.io/kick-js/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/config"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  }
}
