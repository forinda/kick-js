{
  "name": "@forinda/kickjs-db-sqlite",
  "version": "3.1.0",
  "private": true,
  "description": "better-sqlite3 adapter for @forinda/kickjs-db — MigrationAdapter + Kysely SqliteDialect",
  "keywords": [
    "kickjs",
    "nodejs",
    "typescript",
    "sqlite",
    "better-sqlite3",
    "kysely-dialect",
    "kysely",
    "orm-adapter",
    "migrations"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsgo --noEmit",
    "clean": "rm -rf dist .wireit"
  },
  "dependencies": {},
  "peerDependencies": {
    "@forinda/kickjs-db": "workspace:^",
    "kysely": "0.29.2",
    "better-sqlite3": ">=12.0.0"
  },
  "devDependencies": {
    "@forinda/kickjs": "workspace:*",
    "@forinda/kickjs-db": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.2",
    "better-sqlite3": "^12.11.1",
    "kysely": "^0.29.2",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Felix Orinda",
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://kickjs.app/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forinda/kick-js.git",
    "directory": "packages/db-sqlite"
  },
  "bugs": {
    "url": "https://github.com/forinda/kick-js/issues"
  }
}
