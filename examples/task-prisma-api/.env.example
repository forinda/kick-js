PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vibed_prisma

# JWT
JWT_SECRET=your-secret-key-at-least-32-characters-long
JWT_REFRESH_SECRET=your-refresh-secret-at-least-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# App
APP_URL=http://localhost:3000
APP_NAME=Vibed

# Redis (for BullMQ queues)
REDIS_URL=redis://localhost:6379

# Email (Resend — leave empty for ConsoleProvider in dev)
RESEND_API_KEY=
MAIL_FROM_NAME=Vibed
MAIL_FROM_EMAIL=noreply@vibed.dev
